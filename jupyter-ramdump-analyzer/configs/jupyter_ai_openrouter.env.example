# Copy this file to `jupyter_ai_openrouter.env` and fill in your real values.

# OpenRouter API key
OPENROUTER_API_KEY=your_openrouter_key_here

# OpenAI-compatible compatibility vars used by the existing pipeline
OPENAI_API_KEY=your_openrouter_key_here
OPENAI_API_BASE=https://openrouter.ai/api/v1

# Default model for this project
OPENAI_MODEL=openai/gpt-oss-120b:free
OPENAI_FALLBACK_MODEL=openrouter/free

# Jupyter AI / notebook convenience settings
JUPYTER_AI_PROVIDER=openrouter
JUPYTER_AI_MODEL=openai/gpt-oss-120b:free
JUPYTER_AI_FALLBACK_MODEL=openrouter/free
