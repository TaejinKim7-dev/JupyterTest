# Copy this file to `jupyter_ai_openrouter.env` and fill in your real values.
# Start JupyterLab with: ./scripts/start_jupyter.sh

# ── OpenRouter API key (필수) ──────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_key_here

# ── OpenAI-compatible vars (%%ai magic용, start_jupyter.sh가 자동 설정) ───
# OPENROUTER_API_KEY와 같은 값을 넣거나 비워두면 start_jupyter.sh가 복사함
OPENAI_API_KEY=your_openrouter_key_here
OPENAI_API_BASE=https://openrouter.ai/api/v1

# ── 기본 모델 (src/llm_assistant.py 및 분석 파이프라인용) ─────────────────
# LiteLLM 형식 (Jupyternaut Chat UI):  openrouter/<model-id>
# %%ai 매직 형식:                       openai-chat-custom:<model-id>
OPENAI_MODEL=nvidia/nemotron-3-super-120b-a12b
OPENAI_FALLBACK_MODEL=poolside/laguna-m.1:free
